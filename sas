<!DOCTYPE html><html lang="ru"><head>    <meta charset="UTF-8">    <meta name="viewport" content="width=device-width, initial-scale=1.0">    <title id="pageTitle">Гигиена и Здоровье</title>    <style>        :root {            --primary: #2ecc71;            --primary-dark: #27ae60;            --secondary: #3498db;            --accent: #e74c3c;            --warning: #f39c12;            --purple: #764ba2;            --bg: #f0f7f4;            --card-bg: #ffffff;            --text: #2c3e50;            --text-light: #7f8c8d;            --border: #e8f5e9;            --shadow: 0 8px 32px rgba(0,0,0,0.1);        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;            background: var(--bg);            color: var(--text);            min-height: 100vh;        }
        header {            background: linear-gradient(135deg, #2ecc71 0%, #1abc9c 100%);            padding: 28px 20px 24px;            text-align: center;            color: white;            box-shadow: 0 4px 20px rgba(46,204,113,0.4);            position: relative;            overflow: hidden;        }        header::before {            content: '';            position: absolute; top: -40px; right: -40px;            width: 150px; height: 150px;            background: rgba(255,255,255,0.08); border-radius: 50%;            animation: headerPulse 4s ease-in-out infinite;        }        header::after {            content: '';            position: absolute; bottom: -30px; left: -20px;            width: 100px; height: 100px;            background: rgba(255,255,255,0.06); border-radius: 50%;        }        @keyframes headerPulse {            0%,100% { transform: scale(1);    opacity: 0.08; }            50%      { transform: scale(1.15); opacity: 0.14; }        }        header h1 { font-size: 2.2rem; font-weight: 800; letter-spacing: -0.5px; }        header p  { font-size: 1rem; opacity: 0.9; margin-top: 6px; }
        /* ── LANG TOGGLE ── */        .lang-toggle {            position: fixed; top: 14px; right: 14px; z-index: 1100;            background: rgba(255,255,255,0.22);            backdrop-filter: blur(10px);            border: 2px solid rgba(255,255,255,0.55);            border-radius: 50px; padding: 8px 18px;            color: white; font-weight: 800; font-size: 0.88rem;            cursor: pointer; letter-spacing: 0.8px;            box-shadow: 0 4px 18px rgba(0,0,0,0.18);            transition: background 0.3s, transform 0.25s, box-shadow 0.25s;        }        .lang-toggle:hover {            background: rgba(255,255,255,0.38);            transform: translateY(-2px) scale(1.04);            box-shadow: 0 7px 22px rgba(0,0,0,0.22);        }        .lang-toggle.flip { animation: langFlip 0.35s ease; }        @keyframes langFlip {            0%   { transform: rotateY(0deg); }            50%  { transform: rotateY(90deg) scale(0.85); }            100% { transform: rotateY(0deg); }        }
        .date-bar {            background: white; text-align: center;            padding: 12px 20px; font-size: 0.95rem;            color: var(--text-light); border-bottom: 1px solid #e8ecef; font-weight: 500;        }
        .container { max-width: 820px; margin: 0 auto; padding: 24px 16px 40px; }
        /* ── ENTRANCE ── */        @keyframes fadeInUp {            from { opacity: 0; transform: translateY(35px) scale(0.97); }            to   { opacity: 1; transform: translateY(0)    scale(1);    }        }        .fade-in-up {            opacity: 0;            animation: fadeInUp 0.55s cubic-bezier(0.34,1.2,0.64,1) both;        }        .delay-1 { animation-delay: 0.05s; }        .delay-2 { animation-delay: 0.15s; }        .delay-3 { animation-delay: 0.25s; }        .delay-4 { animation-delay: 0.35s; }        .delay-5 { animation-delay: 0.45s; }
        /* ── LANG FADE ── */        @keyframes langFade {            from { opacity: 0; transform: translateY(6px); }            to   { opacity: 1; transform: translateY(0);   }        }        .lang-fade { animation: langFade 0.3s ease both; }
        /* ── STREAK CARD ── */        .streak-card {            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);            border-radius: 24px; padding: 28px 20px 20px;            text-align: center; color: white;            margin-bottom: 22px;            box-shadow: 0 10px 40px rgba(118,75,162,0.35);            position: relative; overflow: hidden;        }        .streak-card::before {            content: '';            position: absolute; top: -50px; right: -30px;            width: 160px; height: 160px;            background: rgba(255,255,255,0.07); border-radius: 50%;        }        .streak-emoji  { font-size: 3.5rem; display: block; margin-bottom: 4px; }        .streak-number { font-size: 5rem; font-weight: 900; line-height: 1; text-shadow: 0 4px 15px rgba(0,0,0,0.2); }        .streak-label  { font-size: 1.1rem; opacity: 0.9; margin-top: 6px; font-weight: 600; }        .streak-best   { font-size: 0.88rem; opacity: 0.75; margin-top: 10px; }
        .streak-calendar {            display: flex; gap: 5px; flex-wrap: wrap;            margin-top: 18px; justify-content: center;        }
        @keyframes calPop {            from { opacity: 0; transform: scale(0.4) rotate(-15deg); }            to   { opacity: 1; transform: scale(1)   rotate(0deg);   }        }        .cal-day {            width: 34px; height: 34px; border-radius: 9px;            background: rgba(255,255,255,0.15);            display: flex; align-items: center; justify-content: center;            font-size: 0.75rem; color: rgba(255,255,255,0.65); font-weight: 600;            transition: transform 0.25s;            animation: calPop 0.4s cubic-bezier(0.34,1.56,0.64,1) both;        }        .cal-day:hover { transform: scale(1.15); }        .cal-day.done  { background: rgba(255,255,255,0.92); color: #764ba2; }        .cal-day.today-mark {            border: 2px solid rgba(255,255,255,0.9); color: white;            box-shadow: 0 0 0 3px rgba(255,255,255,0.25);        }        .cal-day.done.today-mark {            background: rgba(255,255,255,0.92); color: #764ba2; border: 2px solid white;        }        .cal-day.future {            background: rgba(255,255,255,0.05);            border: 1.5px dashed rgba(255,255,255,0.35);            color: rgba(255,255,255,0.35);        }        .cal-label { font-size: 0.8rem; opacity: 0.7; margin-top: 8px; letter-spacing: 0.5px; }
        /* ── CARDS ── */        .card {            background: var(--card-bg); border-radius: 22px;            padding: 26px; margin-bottom: 20px;            box-shadow: var(--shadow); border: 1px solid var(--border);        }        .card-title {            font-size: 1.25rem; font-weight: 700; color: var(--text);            margin-bottom: 20px; display: flex; align-items: center; gap: 10px;        }
        /* ── PROGRESS ── */        .progress-section { margin-bottom: 20px; }        .progress-header {            display: flex; justify-content: space-between;            margin-bottom: 8px; font-size: 0.9rem; font-weight: 600; color: var(--text-light);        }        .progress-bar { height: 13px; background: #ecf0f1; border-radius: 10px; overflow: hidden; }        .progress-fill {            height: 100%;            background: linear-gradient(90deg, var(--primary), var(--primary-dark));            border-radius: 10px;            transition: width 0.5s cubic-bezier(0.4,0,0.2,1);            width: 0%; position: relative; overflow: hidden;        }        .progress-fill::after {            content: '';            position: absolute; top: 0; left: -60%; width: 50%; height: 100%;            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.45), transparent);            animation: progressShimmer 2s linear infinite;        }        @keyframes progressShimmer {            from { left: -60%; }            to   { left: 110%; }        }
        /* ── CHECKLIST ── */        .checklist-item {            display: flex; align-items: center;            padding: 14px 16px; border-radius: 14px; margin-bottom: 10px;            background: #f8fffe; border: 2px solid #e8f5e9;            transition: border-color 0.25s, background 0.25s, transform 0.25s, box-shadow 0.25s;            cursor: pointer; user-select: none;        }        .checklist-item:hover {            border-color: var(--primary); background: #f0fff8;            transform: translateX(5px); box-shadow: -4px 0 0 var(--primary);        }        .checklist-item.checked {            background: #d5f5e3; border-color: var(--primary);            animation: itemCheck 0.4s cubic-bezier(0.34,1.56,0.64,1);        }        @keyframes itemCheck {            0%   { transform: scale(1); }            40%  { transform: scale(1.03) translateX(5px); }            100% { transform: scale(1) translateX(0); }        }        .checklist-item.checked .item-text { text-decoration: line-through; color: var(--text-light); }
        .checkbox-box {            width: 28px; height: 28px; border-radius: 9px;            border: 2.5px solid #bdc3c7; margin-right: 14px;            display: flex; align-items: center; justify-content: center;            flex-shrink: 0; transition: all 0.25s ease;            font-size: 15px; font-weight: 700; color: white;        }        .checklist-item.checked .checkbox-box {            background: var(--primary); border-color: var(--primary);            animation: checkPop 0.4s cubic-bezier(0.34,1.8,0.64,1);        }        @keyframes checkPop {            0%   { transform: scale(1); }            40%  { transform: scale(1.45) rotate(12deg); }            70%  { transform: scale(0.88) rotate(-5deg); }            100% { transform: scale(1) rotate(0deg); }        }        .item-icon { font-size: 1.5rem; margin-right: 13px; flex-shrink: 0; }        .item-text { font-size: 1rem; font-weight: 500; flex: 1; }        .item-time {            font-size: 0.78rem; color: var(--text-light);            background: #f0f3f4; padding: 4px 10px;            border-radius: 20px; font-weight: 500; flex-shrink: 0;        }
        /* ── BANNERS ── */        .all-done-banner {            display: none; text-align: center; padding: 16px;            background: linear-gradient(135deg, #2ecc71, #1abc9c);            border-radius: 14px; color: white; font-weight: 700;            font-size: 1.1rem; margin: 14px 0; animation: popIn 0.4s ease;        }        .all-done-banner.show { display: block; }
        .done-today-msg {            text-align: center; padding: 18px 20px;            background: linear-gradient(135deg, #d5f5e3, #a9dfbf);            border-radius: 14px; margin-top: 14px;            animation: fadeInUp 0.4s ease;        }        .done-today-msg h3 { color: #1e8449; font-size: 1.2rem; margin-bottom: 5px; }        .done-today-msg p  { color: #239b56; font-size: 0.95rem; }
        /* ── BUTTONS ── */        .btn {            display: flex; align-items: center; justify-content: center;            gap: 9px; padding: 15px 24px; border-radius: 14px;            border: none; cursor: pointer; font-size: 1rem; font-weight: 700;            width: 100%; margin-top: 12px; letter-spacing: 0.2px;            position: relative; overflow: hidden;            transition: transform 0.25s, box-shadow 0.25s, filter 0.25s;        }        .btn:hover  { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); filter: brightness(1.05); }        .btn:active { transform: translateY(1px);  box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        /* Ripple */        .ripple {            position: absolute; border-radius: 50%;            background: rgba(255,255,255,0.38);            transform: scale(0);            animation: rippleAnim 0.65s linear;            pointer-events: none;        }        @keyframes rippleAnim { to { transform: scale(5); opacity: 0; } }
        .btn-complete { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; }        .btn-complete:disabled {            opacity: 0.65; cursor: not-allowed;            transform: none !important; box-shadow: none !important; filter: none !important;        }        .btn-how  { background: linear-gradient(135deg, #3498db, #2980b9); color: white; }        .btn-tips { background: linear-gradient(135deg, #f39c12, #e67e22); color: white; }
        /* ══════════════════════════════════════════════           ИСПРАВЛЕНИЕ: btn-warn теперь содержит обе           анимации — сначала появление, затем пульс        ══════════════════════════════════════════════ */        .btn-warn {            background: linear-gradient(135deg, #e74c3c, #c0392b);            color: white;            /* 1) fadeInUp — появление за 0.55s с задержкой 0.25s  */            /* 2) warnPulse — пульс стартует после появления (1s)   */            animation:                fadeInUp  0.55s 0.25s cubic-bezier(0.34,1.2,0.64,1) both,                warnPulse 2.5s  1s    ease-in-out infinite;        }        @keyframes warnPulse {            0%,100% { box-shadow: 0 0 0 0   rgba(231,76,60,0.5), 0 8px 24px rgba(231,76,60,0.3); }            50%      { box-shadow: 0 0 0 12px rgba(231,76,60,0),   0 8px 24px rgba(231,76,60,0.3); }        }        .btn-warn:hover { animation: none; box-shadow: 0 8px 28px rgba(192,57,43,0.45); }
        .btn-close {            background: #ecf0f1; color: var(--text);            width: auto; padding: 11px 22px; margin-top: 20px; font-size: 0.95rem;        }        .btn-close:hover { background: #dfe6e9; transform: none; box-shadow: none; filter: none; }
        /* ── MODALS ── */        .modal-overlay {            display: none; position: fixed; top: 0; left: 0;            width: 100%; height: 100%;            background: rgba(0,0,0,0.55); z-index: 1000;            backdrop-filter: blur(6px);            overflow-y: auto; padding: 24px 16px;            align-items: flex-start; justify-content: center;        }        .modal-overlay.active { display: flex; }        .modal {            background: white; border-radius: 24px; padding: 32px 28px;            max-width: 620px; width: 100%; margin: auto;            box-shadow: 0 24px 80px rgba(0,0,0,0.25);            animation: popIn 0.35s cubic-bezier(0.34,1.56,0.64,1);        }        @keyframes popIn {            from { transform: scale(0.82) translateY(-24px); opacity: 0; }            to   { transform: scale(1)    translateY(0);     opacity: 1; }        }        .modal-header {            display: flex; align-items: center; justify-content: space-between;            margin-bottom: 22px; padding-bottom: 16px; border-bottom: 2px solid var(--border);        }        .modal-title { font-size: 1.35rem; font-weight: 800; color: var(--text); }        .modal-close-x {            width: 36px; height: 36px; border-radius: 50%; border: none;            background: #f0f3f4; cursor: pointer; font-size: 1.1rem; font-weight: 700;            display: flex; align-items: center; justify-content: center;            transition: background 0.2s, transform 0.2s;        }        .modal-close-x:hover { background: #dfe6e9; transform: rotate(90deg); }
        .how-item {            margin-bottom: 16px; padding: 16px 18px;            background: #f8fffe; border-radius: 14px; border-left: 5px solid var(--primary);            animation: fadeInUp 0.35s ease both;        }        .how-item h3 {            font-size: 1rem; font-weight: 700; color: var(--primary-dark);            margin-bottom: 8px; display: flex; align-items: center; gap: 8px;        }        .how-item ul, .how-item p { font-size: 0.9rem; color: #5d6d7e; line-height: 1.65; }        .how-item ul { padding-left: 18px; }        .how-item ul li { margin-bottom: 4px; }
        .tip-item {            margin-bottom: 16px; padding: 16px 18px;            background: #fffbf0; border-radius: 14px; border-left: 5px solid var(--warning);            animation: fadeInUp 0.35s ease both;        }        .tip-item h3 { font-size: 1rem; font-weight: 700; color: #c67c00; margin-bottom: 8px; }        .tip-item p  { font-size: 0.9rem; color: #6e5a2e; line-height: 1.65; }
        .con-modal-item {            display: flex; align-items: flex-start; gap: 12px;            margin-bottom: 12px; padding: 14px 16px;            background: #fff5f5; border-radius: 14px; border-left: 5px solid #e74c3c;            animation: fadeInUp 0.35s ease both;        }        .con-modal-icon {            font-size: 1.5rem; flex-shrink: 0; width: 40px; height: 40px;            background: #ffe5e5; border-radius: 10px;            display: flex; align-items: center; justify-content: center;            border: 1.5px solid #ffbcbc;        }        .con-modal-text { font-size: 0.94rem; color: #922b21; line-height: 1.55; padding-top: 7px; flex: 1; }
        /* ── CONFETTI ── */        .confetti-piece {            position: fixed; top: -20px; z-index: 9999;            pointer-events: none; border-radius: 3px;            animation: confettiFall linear both;        }        @keyframes confettiFall {            0%   { transform: translateY(0)     rotate(0deg)   scaleX(1);  opacity: 1; }            80%  { opacity: 1; }            100% { transform: translateY(105vh) rotate(800deg) scaleX(-1); opacity: 0; }        }
        @keyframes bounce {            0%,100% { transform: scale(1); }            30%     { transform: scale(1.12); }            60%     { transform: scale(0.95); }        }        .bounce-anim { animation: bounce 0.6s ease; }
        @media (max-width: 600px) {            header h1      { font-size: 1.6rem; }            .streak-number { font-size: 4rem; }            .modal         { padding: 22px 16px; }            .card          { padding: 18px; }            .cal-day       { width: 28px; height: 28px; font-size: 0.7rem; }            .lang-toggle   { top: 10px; right: 10px; padding: 6px 12px; font-size: 0.8rem; }        }    </style></head><body>
<button class="lang-toggle" id="langToggle" onclick="toggleLang()">🌐 EN</button>
<header>    <h1 id="headerTitle">Гигиена и Здоровье</h1>    <p  id="headerSub">Твой ежедневный помощник по уходу за собой</p></header><div class="date-bar" id="currentDate"></div>
<div class="container">
    <!-- STREAK -->    <div class="streak-card fade-in-up delay-1" id="streakCard">        <span class="streak-emoji"  id="streakEmoji">💤</span>        <div  class="streak-number" id="streakNumber">0</div>        <div  class="streak-label"  id="streakDaysLabel">дней подряд</div>        <div  class="streak-best"   id="bestLabel">🏆 Лучшая серия: 0 дней</div>        <div  class="streak-calendar" id="calGrid"></div>        <div  class="cal-label"     id="calLabel">14 дней назад · сегодня · +2 дня вперёд</div>    </div>
    <!-- CHECKLIST -->    <div class="card fade-in-up delay-2">        <div class="card-title" id="checklistTitle">📋 Чек-лист гигиены</div>        <div class="progress-section">            <div class="progress-header">                <span id="progressLabel">Прогресс</span>                <span id="progressText">0 / 8</span>            </div>            <div class="progress-bar">                <div class="progress-fill" id="progressFill"></div>            </div>        </div>        <div id="checklistWrap"></div>        <div class="all-done-banner" id="allDoneBanner">🎉 Все задания выполнены! Нажми кнопку ниже!</div>        <div id="todayDoneWrap"></div>        <button class="btn btn-complete" id="completeBtn" onclick="completeToday()">            ✅ Отметить день как выполненный        </button>    </div>
    <!--        ИСПРАВЛЕНИЕ: убраны классы fade-in-up и delay-3.        Теперь анимация появления встроена прямо в .btn-warn        и не конфликтует сама с собой.    -->    <button class="btn btn-warn" id="warnBtn" onclick="openModal('warnModal')">        ⚠️ Последствия невыполнения    </button>
    <button class="btn btn-how  fade-in-up delay-4" id="howBtn"  onclick="openModal('howModal')">        📖 Как правильно выполнять чек-лист?    </button>    <button class="btn btn-tips fade-in-up delay-5" id="tipsBtn" onclick="openModal('tipsModal')">        💡 Советы о здоровом образе жизни    </button>
</div>
<!-- WARN MODAL --><div class="modal-overlay" id="warnModal" onclick="outsideClose(event,'warnModal')">    <div class="modal">        <div class="modal-header">            <div class="modal-title" id="warnModalTitle">⚠️ Последствия невыполнения чек-листа</div>            <button class="modal-close-x" onclick="closeModal('warnModal')">✕</button>        </div>        <div id="warnModalContent"></div>        <div style="text-align:right">            <button class="btn btn-close" id="warnCloseBtn" onclick="closeModal('warnModal')">✕ Закрыть</button>        </div>    </div></div>
<!-- HOW MODAL --><div class="modal-overlay" id="howModal" onclick="outsideClose(event,'howModal')">    <div class="modal">        <div class="modal-header">            <div class="modal-title" id="howModalTitle">📖 Как правильно выполнять чек-лист</div>            <button class="modal-close-x" onclick="closeModal('howModal')">✕</button>        </div>        <div id="howModalContent"></div>        <div style="text-align:right">            <button class="btn btn-close" id="howCloseBtn" onclick="closeModal('howModal')">✕ Закрыть</button>        </div>    </div></div>
<!-- TIPS MODAL --><div class="modal-overlay" id="tipsModal" onclick="outsideClose(event,'tipsModal')">    <div class="modal">        <div class="modal-header">            <div class="modal-title" id="tipsModalTitle">💡 Советы о здоровом образе жизни</div>            <button class="modal-close-x" onclick="closeModal('tipsModal')">✕</button>        </div>        <div id="tipsModalContent"></div>        <div style="text-align:right">            <button class="btn btn-close" id="tipsCloseBtn" onclick="closeModal('tipsModal')">✕ Закрыть</button>        </div>    </div></div>
<script>/* ════════════════════════════════════════   TRANSLATIONS════════════════════════════════════════ */const T = {    ru: {        pageTitle:'Гигиена и Здоровье', headerTitle:'Гигиена и Здоровье',        headerSub:'Твой ежедневный помощник по уходу за собой',        streakDaysLabel:'дней подряд',        calLabel:'14 дней назад · сегодня · +2 дня вперёд',        checklistTitle:'📋 Чек-лист гигиены', progressLabel:'Прогресс',        allDoneBanner:'🎉 Все задания выполнены! Нажми кнопку ниже!',        completeBtnLabel:'✅ Отметить день как выполненный',        completeBtnDone:'✅ Сегодня уже выполнено!',        doneMsgTitle:'🎉 Отлично! Сегодня выполнено!',        doneMsgBody:(s,w)=>`Ты поддерживаешь серию уже <strong>${s}&nbsp;${w}</strong> подряд!`,        warnBtnLabel:'⚠️ Последствия невыполнения',        warnModalTitle:'⚠️ Последствия невыполнения чек-листа',        howBtnLabel:'📖 Как правильно выполнять чек-лист?',        tipsBtnLabel:'💡 Советы о здоровом образе жизни',        howModalTitle:'📖 Как правильно выполнять чек-лист',        tipsModalTitle:'💡 Советы о здоровом образе жизни',        closeBtnLabel:'✕ Закрыть', todayLabel:'Сегодня',        bestLabel:(b,w)=>`🏆 Лучшая серия: ${b} ${w}`,        langToggle:'🌐 EN', dateLocale:'ru-RU',
        items:[            {id:'teeth',    icon:'🦷',text:'Почистить зубы',              time:'Утро и Вечер'},            {id:'face',     icon:'💧',text:'Умыться',                      time:'Утро и Вечер'},            {id:'shower',   icon:'🚿',text:'Принять душ',                  time:'Ежедневно'},            {id:'hair',     icon:'💆',text:'Расчесать волосы',             time:'Утром'},            {id:'hands',    icon:'✋',text:'Вымыть руки перед едой',       time:'Каждый раз'},            {id:'deodorant',icon:'🌬️',text:'Использовать дезодорант',      time:'После душа'},            {id:'clothes',  icon:'👕',text:'Сменить нижнее бельё и носки', time:'Ежедневно'},            {id:'nails',    icon:'💅',text:'Очистить под ногтями',         time:'Ежедневно'}        ],
        consequences:[            {icon:'👃',text:'Неприятный запах изо рта и тела — социальное отстранение окружающих'},            {icon:'🦠',text:'Размножение бактерий — кариес, воспаление дёсен, прыщи и кожные инфекции'},            {icon:'🛡️',text:'Ослабление иммунитета из-за накопления болезнетворных микроорганизмов'},            {icon:'😟',text:'Психологический дискомфорт и снижение уверенности в себе'},            {icon:'🤒',text:'Риск кишечных инфекций, гриппа и ОРВИ при игнорировании мытья рук'},            {icon:'🧴',text:'Ухудшение состояния кожи, волос и ногтей при систематическом пренебрежении'},            {icon:'🦶',text:'Грибковые заболевания стоп и ногтей при редкой смене носков'}        ],
        howItems:[            {title:'🦷 Чистка зубов',html:`<ul>                <li>Минимум <strong>2 минуты</strong>, утром и перед сном</li>                <li>Движения — круговые и вертикальные (не горизонтальные!)</li>                <li>Чисти язык и внутренние поверхности зубов</li>                <li>Используй зубную нить или ирригатор раз в день</li>                <li>Меняй зубную щётку каждые 3 месяца</li></ul>`},            {title:'💧 Умывание лица',html:`<ul>                <li>Умывайся <strong>тёплой</strong> водой (не горячей и не холодной)</li>                <li>Используй мягкое средство для твоего типа кожи</li>                <li>Промокни лицо чистым полотенцем — не три!</li>                <li>Нанеси увлажняющий крем пока кожа чуть влажная</li></ul>`},            {title:'🚿 Душ',html:`<ul>                <li>Оптимальная температура: <strong>37–38°C</strong></li>                <li>Особое внимание: подмышки, шея, пах, стопы между пальцами</li>                <li>Скраб / мочалка 2–3 раза в неделю (не чаще — навредишь коже)</li>                <li>После душа нанеси увлажняющий лосьон</li></ul>`},            {title:'✋ Мытьё рук',html:`<ul>                <li>Мой с мылом не менее <strong>20 секунд</strong></li>                <li>Намыливай между пальцами, тыльную сторону и под ногтями</li>                <li>Обязательно: после улицы, перед едой, после туалета</li>                <li>Тщательно ополаскивай и вытирай насухо</li></ul>`},            {title:'💆 Расчёсывание волос',html:`<ul>                <li>Начинай с кончиков, постепенно поднимаясь к корням</li>                <li>Для мокрых волос — широкий гребень, не щётка</li>                <li>Мой голову по мере загрязнения (1–3 раза в неделю)</li></ul>`},            {title:'🌬️ Дезодорант',html:`<ul>                <li>Наноси на <strong>чистую и сухую</strong> кожу после душа</li>                <li>Антиперспирант лучше наносить <strong>вечером</strong> — он работает ночью</li>                <li>Не наноси на раздражённую или повреждённую кожу</li></ul>`},            {title:'👕 Смена нижнего белья и носков',html:`<p>Меняй каждый день — без исключений. Влажная среда в нижнем белье — идеальная почва для бактерий и грибков. Постирал = здоров.</p>`},            {title:'💅 Очистка под ногтями',html:`<ul>                <li>Чисти под ногтями при каждом мытье рук щёточкой или ногтечисткой</li>                <li>Стриги ногти раз в 1–2 недели</li>                <li>Подпиливай заусенцы — не отрывай руками!</li></ul>`}        ],
        tipItems:[            {title:'💧 Пей достаточно воды',text:'1.5–2.5 литра чистой воды в день. Начинай утро со стакана воды натощак. Вода — основа обмена веществ, красоты кожи и энергии.'},            {title:'🏃 Двигайся каждый день',text:'30 минут умеренной активности снижают риск сердечных заболеваний на 35%. Прогулка, зарядка или танцы — главное регулярность.'},            {title:'😴 Соблюдай режим сна',text:'Взрослому нужно 7–9 часов сна. Ложись и вставай в одно время каждый день, даже в выходные. Хороший сон = сильный иммунитет.'},            {title:'🥦 Питайся сбалансированно',text:'Больше овощей, фруктов, белка и цельнозерновых. Меньше сахара, соли и обработанных продуктов. Не пропускай завтрак.'},            {title:'🧘 Управляй стрессом',text:'Хронический стресс буквально разрушает клетки. Практикуй медитацию, дыхательные упражнения или прогулки на природе.'},            {title:'🚭 Откажись от вредных привычек',text:'Курение и злоупотребление алкоголем разрушают здоровье постепенно, но неизбежно. Замени вредные ритуалы на полезные.'},            {title:'👁️ Береги зрение',text:'Правило 20-20-20: каждые 20 минут смотри на предмет в 6 метрах от тебя в течение 20 секунд.'},            {title:'🌞 Получай витамин D',text:'15–20 минут на солнце в день покрывают дневную норму. Витамин D необходим для иммунитета, костей и настроения.'},            {title:'🤝 Поддерживай социальные связи',text:'Одиночество так же вредно, как 15 сигарет в день. Общение с близкими буквально продлевает жизнь.'},            {title:'🩺 Проходи профилактические осмотры',text:'Посещай врача и стоматолога хотя бы раз в год. Большинство серьёзных болезней лечатся легко при раннем обнаружении.'}        ]    },
    en: {        pageTitle:'Hygiene & Health', headerTitle:'Hygiene & Health',        headerSub:'Your daily self-care assistant',        streakDaysLabel:'days in a row',        calLabel:'14 days ago · today · +2 days ahead',        checklistTitle:'📋 Hygiene Checklist', progressLabel:'Progress',        allDoneBanner:'🎉 All tasks done! Press the button below!',        completeBtnLabel:'✅ Mark day as completed',        completeBtnDone:'✅ Already completed today!',        doneMsgTitle:'🎉 Great! Today is done!',        doneMsgBody:(s,w)=>`You've kept your streak for <strong>${s}&nbsp;${w}</strong> in a row!`,        warnBtnLabel:'⚠️ Consequences of Skipping',        warnModalTitle:'⚠️ Consequences of skipping the checklist',        howBtnLabel:'📖 How to properly follow the checklist?',        tipsBtnLabel:'💡 Healthy Lifestyle Tips',        howModalTitle:'📖 How to properly follow the checklist',        tipsModalTitle:'💡 Healthy Lifestyle Tips',        closeBtnLabel:'✕ Close', todayLabel:'Today',        bestLabel:(b,w)=>`🏆 Best streak: ${b} ${w}`,        langToggle:'🌐 RU', dateLocale:'en-US',
        items:[            {id:'teeth',    icon:'🦷',text:'Brush teeth',             time:'Morning & Evening'},            {id:'face',     icon:'💧',text:'Wash face',               time:'Morning & Evening'},            {id:'shower',   icon:'🚿',text:'Take a shower',           time:'Daily'},            {id:'hair',     icon:'💆',text:'Comb hair',               time:'Morning'},            {id:'hands',    icon:'✋',text:'Wash hands before eating',time:'Every time'},            {id:'deodorant',icon:'🌬️',text:'Apply deodorant',         time:'After shower'},            {id:'clothes',  icon:'👕',text:'Change underwear & socks',time:'Daily'},            {id:'nails',    icon:'💅',text:'Clean under nails',       time:'Daily'}        ],
        consequences:[            {icon:'👃',text:'Bad breath and body odor — social rejection by those around you'},            {icon:'🦠',text:'Bacterial growth — cavities, gum inflammation, acne and skin infections'},            {icon:'🛡️',text:'Weakened immunity due to accumulation of harmful microorganisms'},            {icon:'😟',text:'Psychological discomfort and reduced self-confidence'},            {icon:'🤒',text:'Risk of intestinal infections, flu and colds when skipping hand washing'},            {icon:'🧴',text:'Deterioration of skin, hair and nails with systematic neglect'},            {icon:'🦶',text:'Fungal diseases of feet and nails from rarely changing socks'}        ],
        howItems:[            {title:'🦷 Brushing Teeth',html:`<ul>                <li>At least <strong>2 minutes</strong>, morning and before bed</li>                <li>Use circular and vertical motions (not horizontal!)</li>                <li>Clean your tongue and inner tooth surfaces</li>                <li>Use dental floss or a water flosser once a day</li>                <li>Replace your toothbrush every 3 months</li></ul>`},            {title:'💧 Washing Your Face',html:`<ul>                <li>Use <strong>warm</strong> water (not hot or cold)</li>                <li>Use a gentle cleanser suited to your skin type</li>                <li>Pat dry with a clean towel — don't rub!</li>                <li>Apply moisturiser while skin is still slightly damp</li></ul>`},            {title:'🚿 Showering',html:`<ul>                <li>Optimal temperature: <strong>37–38 °C (98–100 °F)</strong></li>                <li>Pay extra attention to: armpits, neck, groin, feet between toes</li>                <li>Exfoliate 2–3 times a week (not more — it can damage skin)</li>                <li>Apply a moisturising lotion after showering</li></ul>`},            {title:'✋ Washing Hands',html:`<ul>                <li>Wash with soap for at least <strong>20 seconds</strong></li>                <li>Lather between fingers, the back of hands and under nails</li>                <li>Always wash: after being outside, before eating, after the toilet</li>                <li>Rinse thoroughly and dry completely</li></ul>`},            {title:'💆 Combing Hair',html:`<ul>                <li>Start from the tips, gradually working up to the roots</li>                <li>For wet hair — use a wide-tooth comb, not a brush</li>                <li>Wash hair as needed (1–3 times a week)</li></ul>`},            {title:'🌬️ Deodorant',html:`<ul>                <li>Apply to <strong>clean and dry</strong> skin after showering</li>                <li>Antiperspirant is best applied <strong>in the evening</strong> — it works overnight</li>                <li>Do not apply to irritated or broken skin</li></ul>`},            {title:'👕 Changing Underwear & Socks',html:`<p>Change every single day — no exceptions. Moist environments in underwear are the perfect breeding ground for bacteria and fungi.</p>`},            {title:'💅 Cleaning Under Nails',html:`<ul>                <li>Clean under nails with a brush each time you wash your hands</li>                <li>Trim nails every 1–2 weeks</li>                <li>File hangnails — don't rip them off!</li></ul>`}        ],
        tipItems:[            {title:'💧 Drink enough water',text:'1.5–2.5 litres of clean water per day. Start your morning with a glass of water on an empty stomach. Water is the basis of metabolism, skin beauty and energy.'},            {title:'🏃 Move every day',text:'30 minutes of moderate activity reduces the risk of heart disease by 35%. A walk, workout or dancing — consistency matters more than intensity.'},            {title:'😴 Keep a sleep schedule',text:'Adults need 7–9 hours of sleep. Go to bed and wake up at the same time every day, even on weekends. Good sleep = strong immunity and better focus.'},            {title:'🥦 Eat a balanced diet',text:'More vegetables, fruit, protein and whole grains. Less sugar, salt and processed foods. Don\'t skip breakfast — it kickstarts your metabolism.'},            {title:'🧘 Manage stress',text:'Chronic stress literally damages cells. Practise meditation, breathing exercises or walks in nature. Even 10 minutes of quiet a day makes a difference.'},            {title:'🚭 Quit bad habits',text:'Smoking and excessive alcohol gradually but inevitably destroy your health. Replace harmful rituals with healthy ones.'},            {title:'👁️ Protect your eyesight',text:'The 20-20-20 rule: every 20 minutes look at something 6 metres away for 20 seconds.'},            {title:'🌞 Get vitamin D',text:'15–20 minutes in the sun per day covers your daily needs. Vitamin D is essential for immunity, bones and mood.'},            {title:'🤝 Maintain social connections',text:'Loneliness is as harmful as smoking 15 cigarettes a day. Connecting with loved ones literally extends life.'},            {title:'🩺 Get regular check-ups',text:'Visit your doctor and dentist at least once a year. Most serious diseases are easily treated when caught early.'}        ]    }};
/* ════════════════════════════════════════   STATE════════════════════════════════════════ */let currentLang = localStorage.getItem('hy_lang') || 'ru';let checked     = new Set();let todayDone   = false;
const lang         = ()  => T[currentLang];const todayStr     = ()  => new Date().toISOString().split('T')[0];const yesterdayStr = ()  => { const d=new Date(); d.setDate(d.getDate()-1); return d.toISOString().split('T')[0]; };const lsGet        = (k,def) => { try { return JSON.parse(localStorage.getItem(k))??def; } catch { return def; } };const lsSet        = (k,v)   => localStorage.setItem(k, JSON.stringify(v));
function daysWord(n) {    if (currentLang==='en') return n===1?'day':'days';    const a=Math.abs(n);    if (a%100>=11&&a%100<=19) return 'дней';    if (a%10===1)              return 'день';    if (a%10>=2&&a%10<=4)     return 'дня';    return 'дней';}
/* ── RIPPLE ── */document.addEventListener('click', e => {    const btn = e.target.closest('.btn');    if (!btn || btn.disabled) return;    const r = document.createElement('span');    r.className = 'ripple';    const rect = btn.getBoundingClientRect();    const size = Math.max(rect.width, rect.height);    r.style.cssText = `width:${size}px;height:${size}px;        left:${e.clientX-rect.left-size/2}px;        top:${e.clientY-rect.top-size/2}px`;    btn.appendChild(r);    setTimeout(()=>r.remove(), 700);});
/* ── CONFETTI ── */function launchConfetti() {    const colors=['#2ecc71','#3498db','#f39c12','#e74c3c','#9b59b6','#1abc9c','#f1c40f'];    for (let i=0;i<70;i++) {        const el=document.createElement('div');        el.className='confetti-piece';        const size=7+Math.random()*9;        el.style.cssText=`            left:${Math.random()*100}vw;            width:${size}px;height:${size}px;            background:${colors[Math.floor(Math.random()*colors.length)]};            border-radius:${Math.random()>0.45?'50%':'3px'};            animation-delay:${Math.random()*0.6}s;            animation-duration:${1.1+Math.random()*1.2}s;`;        document.body.appendChild(el);        setTimeout(()=>el.remove(), 2200);    }}
/* ════════════════════════════════════════   INIT════════════════════════════════════════ */function init() {    applyLang(false);    checkStreakBreak();    loadTodayState();    renderChecklist();    updateProgress();    updateStreakUI();    renderCalendar();}
/* ── LANGUAGE ── */function toggleLang() {    currentLang = currentLang==='ru'?'en':'ru';    lsSet('hy_lang', currentLang);    const btn=document.getElementById('langToggle');    btn.classList.add('flip');    setTimeout(()=>btn.classList.remove('flip'),350);    applyLang(true);}
function applyLang(animate) {    const L=lang();    document.documentElement.lang=currentLang;    document.title=L.pageTitle;
    const map={        langToggle:L.langToggle, headerTitle:L.headerTitle, headerSub:L.headerSub,        streakDaysLabel:L.streakDaysLabel, calLabel:L.calLabel,        checklistTitle:L.checklistTitle, progressLabel:L.progressLabel,        allDoneBanner:L.allDoneBanner,        warnBtn:L.warnBtnLabel, howBtn:L.howBtnLabel, tipsBtn:L.tipsBtnLabel,        warnModalTitle:L.warnModalTitle, howModalTitle:L.howModalTitle, tipsModalTitle:L.tipsModalTitle,        warnCloseBtn:L.closeBtnLabel, howCloseBtn:L.closeBtnLabel, tipsCloseBtn:L.closeBtnLabel,    };    Object.entries(map).forEach(([id,text])=>{        const el=document.getElementById(id);        if (!el) return;        el.innerHTML=text;        if (animate){el.classList.remove('lang-fade');void el.offsetWidth;el.classList.add('lang-fade');}    });
    const cBtn=document.getElementById('completeBtn');    if (cBtn) cBtn.innerHTML=todayDone?L.completeBtnDone:L.completeBtnLabel;
    renderDate();    renderChecklist();    updateStreakUI();    renderCalendar();    renderWarnModal();    renderHowModal();    renderTipsModal();    if (todayDone) showDoneMsg();}
/* ── DATE ── */function renderDate() {    const opts={weekday:'long',year:'numeric',month:'long',day:'numeric'};    document.getElementById('currentDate').textContent =        '📅 '+new Date().toLocaleDateString(lang().dateLocale, opts);}
/* ── STREAK BREAK ── */function checkStreakBreak() {    const last=lsGet('hy_lastDate','');    if (last && last!==todayStr() && last!==yesterdayStr()) lsSet('hy_streak',0);}
/* ── LOAD STATE ── */function loadTodayState() {    const last=lsGet('hy_lastDate','');    const savedD=lsGet('hy_checkedDate','');    todayDone=(last===todayStr());    if (todayDone||savedD===todayStr()) checked=new Set(lsGet('hy_todayChecked',[]));    else checked=new Set();    if (!todayDone) lsSet('hy_checkedDate',todayStr());}
/* ── CHECKLIST ── */function renderChecklist() {    const wrap=document.getElementById('checklistWrap');    wrap.innerHTML='';    lang().items.forEach((item,idx)=>{        const isC=checked.has(item.id);        const div=document.createElement('div');        div.className='checklist-item'+(isC?' checked':'')+' fade-in-up';        div.style.animationDelay=`${0.05*idx}s`;        div.id='ci-'+item.id;        div.setAttribute('role','checkbox');        div.setAttribute('aria-checked',isC);        div.onclick=()=>toggleItem(item.id);        div.innerHTML=`            <div class="checkbox-box">${isC?'✓':''}</div>            <span class="item-icon">${item.icon}</span>            <span class="item-text">${item.text}</span>            <span class="item-time">${item.time}</span>`;        wrap.appendChild(div);    });    if (todayDone){        wrap.querySelectorAll('.checklist-item').forEach(el=>el.style.cursor='default');        showDoneMsg();        const btn=document.getElementById('completeBtn');        if (btn){btn.disabled=true;btn.innerHTML=lang().completeBtnDone;}    }}
function toggleItem(id) {    if (todayDone) return;    checked.has(id)?checked.delete(id):checked.add(id);    const el=document.getElementById('ci-'+id);    const isNow=checked.has(id);    el.className='checklist-item'+(isNow?' checked':'');    el.querySelector('.checkbox-box').textContent=isNow?'✓':'';    el.setAttribute('aria-checked',isNow);    lsSet('hy_todayChecked',[...checked]);    lsSet('hy_checkedDate',todayStr());    updateProgress();}
function updateProgress() {    const done=checked.size, total=lang().items.length;    document.getElementById('progressText').textContent=`${done} / ${total}`;    document.getElementById('progressFill').style.width=Math.round(done/total*100)+'%';    const banner=document.getElementById('allDoneBanner');    (done===total&&!todayDone)?banner.classList.add('show'):banner.classList.remove('show');}
/* ── COMPLETE DAY ── */function completeToday() {    if (todayDone) return;    lang().items.forEach(i=>checked.add(i.id));
    const today=todayStr(), yest=yesterdayStr();    const last=lsGet('hy_lastDate','');    let streak=lsGet('hy_streak',0), best=lsGet('hy_best',0);    streak=(last===yest)?streak+1:1;    if (streak>best){best=streak;lsSet('hy_best',best);}    lsSet('hy_streak',streak);lsSet('hy_lastDate',today);    lsSet('hy_todayChecked',[...checked]);lsSet('hy_checkedDate',today);
    let hist=lsGet('hy_history',[]);    if (!hist.includes(today)){hist.push(today);if(hist.length>30)hist=hist.slice(-30);lsSet('hy_history',hist);}
    todayDone=true;    document.querySelectorAll('.checklist-item').forEach(el=>{        el.className='checklist-item checked';        el.querySelector('.checkbox-box').textContent='✓';        el.style.cursor='default';    });    document.getElementById('allDoneBanner').classList.remove('show');    updateProgress();updateStreakUI();renderCalendar();showDoneMsg();    const btn=document.getElementById('completeBtn');    btn.disabled=true;btn.innerHTML=lang().completeBtnDone;    launchConfetti();    const card=document.getElementById('streakCard');    card.classList.add('bounce-anim');    setTimeout(()=>card.classList.remove('bounce-anim'),700);}
function showDoneMsg() {    const s=lsGet('hy_streak',0);    document.getElementById('todayDoneWrap').innerHTML=`        <div class="done-today-msg">            <h3>${lang().doneMsgTitle}</h3>            <p>${lang().doneMsgBody(s,daysWord(s))}</p>        </div>`;}
/* ── STREAK UI ── */function updateStreakUI() {    const s=lsGet('hy_streak',0), b=lsGet('hy_best',0);    document.getElementById('streakNumber').textContent=s;    document.getElementById('bestLabel').textContent=lang().bestLabel(b,daysWord(b));    document.getElementById('streakDaysLabel').textContent=lang().streakDaysLabel;    const em=['💤','🌱','🌱','🔥','🔥','🔥','🔥','⚡','⚡','⚡','⚡','⚡','⚡','⚡','🏆'];    document.getElementById('streakEmoji').textContent=em[Math.min(s,em.length-1)];}
/* ── CALENDAR ── */function renderCalendar() {    const hist=lsGet('hy_history',[]), today=todayStr();    const grid=document.getElementById('calGrid');    grid.innerHTML='';    document.getElementById('calLabel').textContent=lang().calLabel;    for (let i=13;i>=-2;i--){        const d=new Date();d.setDate(d.getDate()-i);        const ds=d.toISOString().split('T')[0];        const el=document.createElement('div');        el.className='cal-day';        el.style.animationDelay=`${(13-i)*0.03}s`;        if (i<0)            el.classList.add('future');        if (hist.includes(ds)) el.classList.add('done');        if (ds===today)     el.classList.add('today-mark');        el.textContent=d.getDate();        el.title=i===0?lang().todayLabel:i<0?`+${Math.abs(i)}`:ds;        grid.appendChild(el);    }}
/* ── MODAL CONTENT ── */function renderWarnModal(){    document.getElementById('warnModalContent').innerHTML=        lang().consequences.map(c=>`            <div class="con-modal-item">                <div class="con-modal-icon">${c.icon}</div>                <div class="con-modal-text">${c.text}</div>            </div>`).join('');}function renderHowModal(){    document.getElementById('howModalContent').innerHTML=        lang().howItems.map(i=>`            <div class="how-item"><h3>${i.title}</h3>${i.html}</div>`).join('');}function renderTipsModal(){    document.getElementById('tipsModalContent').innerHTML=        lang().tipItems.map(i=>`            <div class="tip-item"><h3>${i.title}</h3><p>${i.text}</p></div>`).join('');}
/* ── MODALS ── */function openModal(id){    if(id==='warnModal') renderWarnModal();    if(id==='howModal')  renderHowModal();    if(id==='tipsModal') renderTipsModal();    document.getElementById(id).classList.add('active');    document.body.style.overflow='hidden';}function closeModal(id){    document.getElementById(id).classList.remove('active');    if(!document.querySelector('.modal-overlay.active')) document.body.style.overflow='';}function outsideClose(e,id){ if(e.target===document.getElementById(id)) closeModal(id); }
document.addEventListener('keydown',e=>{    if(e.key==='Escape') ['warnModal','howModal','tipsModal'].forEach(closeModal);});
init();</script></body></html>
